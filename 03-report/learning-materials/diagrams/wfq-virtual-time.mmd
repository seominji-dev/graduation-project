%% WFQ (Weighted Fair Queuing) with Virtual Time
%% Mermaid flowchart diagram

flowchart TB
    subgraph Tenants["테넌트 등록"]
        T1["Enterprise<br/>Weight: 100"]
        T2["Premium<br/>Weight: 50"]
        T3["Standard<br/>Weight: 10"]
        T4["Free<br/>Weight: 1"]
    end

    subgraph VT["Virtual Time 계산"]
        Formula["Virtual Finish Time =<br/>Virtual Start Time + (Service Time / Weight)"]
        
        VT1["Enterprise: VFT = 0 + (10/100) = 0.1"]
        VT2["Premium: VFT = 0 + (10/50) = 0.2"]
        VT3["Standard: VFT = 0 + (10/10) = 1.0"]
        VT4["Free: VFT = 0 + (10/1) = 10.0"]
    end

    subgraph Scheduling["스케줄링 순서"]
        S1["1. Enterprise (VFT: 0.1)"]
        S2["2. Premium (VFT: 0.2)"]
        S3["3. Standard (VFT: 1.0)"]
        S4["4. Free (VFT: 10.0)"]
    end

    subgraph Fairness["공정성 측정"]
        JFI["Jain's Fairness Index<br/>J = (Σxi)² / (n × Σxi²)<br/>목표: 0.95 이상"]
        Result["달성: 0.92-0.98<br/>(매우 높은 공정성)"]
    end

    Tenants --> VT
    VT --> Scheduling
    Scheduling --> Fairness

    style S1 fill:#90EE90,stroke:#333
    style Result fill:#87CEEB,stroke:#333
