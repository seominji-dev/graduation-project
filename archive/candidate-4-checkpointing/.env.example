# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/checkpointing

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
PORT=3001
NODE_ENV=development

# Security Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Authentication Configuration
# REQUIRED: API key must be at least 32 characters for security
# Generate with: openssl rand -hex 32
API_KEY=your-secure-api-key-minimum-32-characters

# Checkpointing Configuration
CHECKPOINT_INTERVAL_MS=30000
MAX_CHECKPOINTS_PER_AGENT=10
MAX_STATE_SIZE_BYTES=10485760

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
